# Mycelium — example environment config
# Copy to .env and adjust. (.env is gitignored)

# Core
APP_NAME=Mycelium
SECRET_KEY=change-me-please
DATABASE_URL=sqlite:///storage/mycelium.db
COOKIE_SECURE=false
DB_MIGRATION_MODE=create_all
DB_AUTO_CREATE_TABLES=true

# SaaS (optional): enable CORS if you serve a separate frontend domain
# CORS_ALLOW_ORIGINS_CSV=https://app.example.com
# CORS_ALLOW_CREDENTIALS=true

# Hive
HIVE_ENABLED=true
HIVE_EXPORT_ENABLED_DEFAULT=false
HIVE_WISDOM_MIN_WHISPERS=2
HIVE_WISDOM_MIN_DEVICES=1
HIVE_WISDOM_CONSENSUS_FRACTION=0.5

# Parent hub: allow headless child ingest (recommended when using Tailscale)
# Children send: X-Hive-Token: <token>
HIVE_INGEST_TOKEN=change-me-please

# Parent hub: optionally restrict Hive Health view to parent accounts
# Comma-separated emails. Leave empty to allow any authenticated user.
HIVE_HEALTH_ALLOWLIST_EMAILS_CSV=

# Optional knobs
NEXUS_DEVICE_ID=parent-hub
NEXUS_HOMEOSTASIS_ENABLED=true
NEXUS_HOMEOSTASIS_TICK_SECONDS=30

# Telemetry assistant (nudges from consented digital signals)
# Disabled by default; enable when your brain hub is collecting telemetry.
NEXUS_TELEMETRY_ASSISTANT_ENABLED=false
NEXUS_TELEMETRY_ASSISTANT_TICK_SECONDS=60
NEXUS_TELEMETRY_ASSISTANT_WINDOW_HOURS=6
NEXUS_TELEMETRY_ASSISTANT_CONFIDENCE_THRESHOLD=0.85
NEXUS_TELEMETRY_ASSISTANT_THROTTLE_MINUTES=120

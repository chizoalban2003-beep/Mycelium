# Mycelium — environment configuration
# Copy to ~/.mycelium/.env and fill in your values.
# Generate automatically: mycelium setup
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Security (required in production)
# ---------------------------------------------------------------------------
# JWT signing secret — generate: python3 -c "import secrets; print(secrets.token_hex(32))"
MYCELIUM_SECRET=change-me-generate-with-mycelium-setup

# Require bearer token on all API endpoints (set 0 for pure local single-user)
MYCO_REQUIRE_AUTH=1

# Optional password gate at /auth/token (leave blank = no password required)
MYCO_PASSWORD=

# Rate limiting: max requests per window
MYCO_RATE_LIMIT=60
MYCO_RATE_WINDOW=60

# ---------------------------------------------------------------------------
# TLS (HTTPS) — generated by `mycelium setup`
# ---------------------------------------------------------------------------
# MYCO_TLS_CERT=~/.mycelium/tls/cert.pem
# MYCO_TLS_KEY=~/.mycelium/tls/key.pem

# ---------------------------------------------------------------------------
# LLM (optional — Mycelium works fully offline with ollama)
# Get your key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Ollama model (default: llama3.2). Requires: ollama pull llama3.2
MYCO_OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Companion settings (all optional — sensible defaults apply)
# ---------------------------------------------------------------------------

# Name shown in greetings and notifications
MYCO_NAME=Myco

# Where Myco stores all persistent data (soul, model, memory, goals)
MYCO_DATA_DIR=~/.mycelium

# Response verbosity: concise | normal | verbose
MYCO_VERBOSITY=normal

# Comma-separated directories to watch for new data files
# Example: MYCO_WATCH_DIRS=~/Downloads,~/Documents/data
MYCO_WATCH_DIRS=

# ---------------------------------------------------------------------------
# REST API server
# ---------------------------------------------------------------------------
MYCO_HOST=127.0.0.1
MYCO_PORT=8000

# ---------------------------------------------------------------------------
# CommBridge — digital communication (Stage 143)
# ---------------------------------------------------------------------------

# Email (SMTP) — required for send_email
MYCO_EMAIL_HOST=smtp.gmail.com
MYCO_EMAIL_PORT=587
MYCO_EMAIL_USER=you@gmail.com
MYCO_EMAIL_PASS=your-app-password

# SMS via Twilio — required for send_sms (pip install twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# Slack — required for send_slack (Incoming Webhook URL)
MYCO_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...

# ---------------------------------------------------------------------------
# DesktopBridge — local task automation (Stage 144)
# ---------------------------------------------------------------------------

# Set to 1 to allow file write/delete operations
MYCO_ALLOW_WRITES=0

# Mycelium — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# LLM (optional — enables intelligent chat, LLM-driven goal planning)
# Get your key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-key-here

# ---------------------------------------------------------------------------
# Companion settings (all optional — sensible defaults apply)
# ---------------------------------------------------------------------------

# Name shown in greetings and notifications
MYCO_NAME=Myco

# Where Myco stores all persistent data (soul, model, memory, goals)
MYCO_DATA_DIR=~/.mycelium

# Response verbosity: concise | normal | verbose
MYCO_VERBOSITY=normal

# Comma-separated directories to watch for new data files
# Example: MYCO_WATCH_DIRS=~/Downloads,~/Documents/data
MYCO_WATCH_DIRS=

# ---------------------------------------------------------------------------
# REST API server
# ---------------------------------------------------------------------------
MYCO_HOST=0.0.0.0
MYCO_PORT=8000

# Secret key used to sign JWT tokens for the REST API
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
MYCO_SECRET_KEY=change-me-before-production

# ---------------------------------------------------------------------------
# CommBridge — digital communication (Stage 143)
# ---------------------------------------------------------------------------

# Email (SMTP) — required for send_email
MYCO_EMAIL_HOST=smtp.gmail.com
MYCO_EMAIL_PORT=587
MYCO_EMAIL_USER=you@gmail.com
MYCO_EMAIL_PASS=your-app-password

# SMS via Twilio — required for send_sms (pip install twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# Slack — required for send_slack (Incoming Webhook URL)
MYCO_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...

# ---------------------------------------------------------------------------
# DesktopBridge — local task automation (Stage 144)
# ---------------------------------------------------------------------------

# Set to 1 to allow file write/delete operations
MYCO_ALLOW_WRITES=0

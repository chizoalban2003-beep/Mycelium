# Mycelium — production environment example
# Copy to Railway env vars or a managed secret file and replace placeholders.

# Core
APP_NAME=Mycelium
SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=postgresql+psycopg://mycelium:replace-with-password@your-postgres-host:5432/mycelium
COOKIE_SECURE=true
DB_MIGRATION_MODE=migrate
DB_AUTO_CREATE_TABLES=false
CORS_ALLOW_ORIGINS_CSV=https://your-public-app.example.com
CORS_ALLOW_CREDENTIALS=true

# Runtime / deployment
NEXUS_DEVICE_ID=parent-hub
NEXUS_HOMEOSTASIS_ENABLED=true
HIVE_ENABLED=true
HIVE_EXPORT_ENABLED_DEFAULT=false
HIVE_INGEST_TOKEN=replace-with-long-random-token
HIVE_HEALTH_ALLOWLIST_EMAILS_CSV=

# Optional production hardening / operations
STRICT_PRODUCTION=true

# Optional external messaging
APP_PUBLIC_BASE_URL=https://your-public-app.example.com
NOTIFICATIONS_BRIDGE_ENABLED=false
NOTIFICATIONS_TELEGRAM_BOT_TOKEN=
NOTIFICATIONS_TELEGRAM_WEBHOOK_SECRET=

# Optional SMTP recovery
MAIL_ENABLED=false
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_USE_TLS=true
MAIL_SMTP_USE_SSL=false

# Android TWA verification
ANDROID_APP_PACKAGE_NAME=
ANDROID_APP_SHA256_CERT_FINGERPRINTS_CSV=

# Telemetry assistant (enable only if you want background nudges)
NEXUS_TELEMETRY_ASSISTANT_ENABLED=false
NEXUS_TELEMETRY_ASSISTANT_TICK_SECONDS=60
NEXUS_TELEMETRY_ASSISTANT_WINDOW_HOURS=6
NEXUS_TELEMETRY_ASSISTANT_CONFIDENCE_THRESHOLD=0.85
NEXUS_TELEMETRY_ASSISTANT_THROTTLE_MINUTES=120
